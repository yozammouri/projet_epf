{% extends 'base.html.twig' %}

{% block title %}Delete{% endblock %}

{% block body %}
{% for message in app.flashes('success') %}
    <div class="alert alert-success flash-message">
        {{ message }}
    </div>
{% endfor %}

{% for message in app.flashes('Created') %}
    <div class="alert alert-success flash-message">
        {{ message }}
    </div>
{% endfor %}

<div class="container mt-150">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0 fw-bold">Members</h1>
        <a href="{{ path('app_etudiant_new') }}" class="btn btn-success">+ Create New Student</a>
    </div>

    <!-- Header Row -->
    <div class="list-group-item d-flex fw-bold border bg-light">
        <div class="col">Last Name</div>
        <div class="col">First Name</div>
        <div class="col text-end">Actions</div>
    </div>

    <!-- Students List -->
    <ul class="list-group">
        {% for etudiant in etudiants %}
            <li class="list-group-item d-flex align-items-center">
                <div class="col">{{ etudiant.nom|e }}</div>
                <div class="col">{{ etudiant.prenom|e }}</div>
                <div class="col text-end">
                    <a href="{{ path('app_etudiant_edit', { id: etudiant.id }) }}" class="btn btn-sm btn-primary me-2">Edit</a>
                    <form action="{{ path('app_etudiant_delete', { id: etudiant.id }) }}" method="post" style="display:inline;">
                        {# {{ csrf_token('delete' ~ etudiant.id) }} #}
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn btn-sm text-danger fw-bold border-danger" onclick="return confirm('Are you sure you want to delete this student?');">Delete</button>
                    </form>
                </div>
            </li>
        {% else %}
            <li class="list-group-item text-muted">No students found.</li>
        {% endfor %}
    </ul>
</div>


{% endblock %}
